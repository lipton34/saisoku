generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GbfMasterKind {
  character
  weapon
  summon
  job
  material
  quest
}

enum SourceArticleStatus {
  active
  archived
  fetch_error
}

enum SourceArticleType {
  monthly_plan
  event
  campaign
  update
  gacha
  character
  media
  maintenance
  other
}

enum ExtractedNewsItemType {
  event
  campaign
  update
  monthly_plan_item
  gacha
  character
  maintenance
  other
}

enum ExtractedNewsEventType {
  scenario_event
  rerun_event
  collaboration_event
  guild_war
  dread_barrage
  rotb
  xeno_clash
  proving_grounds
  tower_of_babyl
  arcarum_event
  side_story
  special_event
  unknown
}

enum ExtractedNewsInfoStatus {
  confirmed
  scheduled
  tentative
  unknown
}

model User {
  id                   String                    @id @default(cuid())
  username             String                    @unique
  passwordHash         String
  displayName          String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  roundGoals           RoundGoal[]
  progressGoals        ProgressGoal[]
  itemInventories      UserItemInventory[]
  progressSharedValues UserProgressSharedValue[]
  buildPosts           BuildPost[]
  buildDrafts          BuildDraft[]
  guildWarGoalPlans    GuildWarGoalPlan[]
  goals                Goal[]
}

model RoundGoal {
  id           String   @id @default(cuid())
  title        String
  targetCount  Int      @map("target_count")
  currentCount Int      @default(0) @map("current_count")
  note         String?
  sortOrder    Int      @default(0) @map("sort_order")
  ownerId      String   @map("owner_id")
  owner        User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  boardGoal    Goal?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ownerId, sortOrder])
  @@map("round_goals")
}

model ProgressGoal {
  id              String                      @id @default(cuid())
  presetId        String                      @map("preset_id")
  presetVersion   Int                         @map("preset_version")
  presetName      String                      @map("preset_name")
  targetId        String                      @map("target_id")
  targetName      String                      @map("target_name")
  selection       Json                        @default("{}")
  goalStageId     String                      @map("goal_stage_id")
  startingStageId String?                     @map("starting_stage_id")
  sortOrder       Int                         @default(0) @map("sort_order")
  ownerId         String                      @map("owner_id")
  owner           User                        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  boardGoal       Goal?
  stages          ProgressStageProgress[]
  conditions      ProgressConditionProgress[]
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@index([ownerId, updatedAt])
  @@index([ownerId, presetId, targetId, goalStageId])
  @@map("progress_goals")
}

model UserItemInventory {
  id         String   @id @default(cuid())
  ownerId    String   @map("owner_id")
  itemKey    String   @map("item_key")
  itemName   String   @map("item_name")
  ownedCount Int      @default(0) @map("owned_count")
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([ownerId, itemKey])
  @@index([ownerId, itemName])
  @@map("user_item_inventories")
}

model UserProgressSharedValue {
  id        String   @id @default(cuid())
  ownerId   String   @map("owner_id")
  valueKey  String   @map("value_key")
  value     Int      @default(0)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([ownerId, valueKey])
  @@map("user_progress_shared_values")
}

model ProgressStageProgress {
  id             String       @id @default(cuid())
  goalId         String       @map("goal_id")
  stageId        String       @map("stage_id")
  isManuallyDone Boolean      @default(false) @map("is_manually_done")
  completedAt    DateTime?    @map("completed_at")
  goal           ProgressGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([goalId, stageId])
  @@index([goalId])
  @@map("progress_stage_progresses")
}

model ProgressConditionProgress {
  id           String       @id @default(cuid())
  goalId       String       @map("goal_id")
  conditionId  String       @map("condition_id")
  isChecked    Boolean      @default(false) @map("is_checked")
  numericValue Int?         @map("numeric_value")
  goal         ProgressGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([goalId, conditionId])
  @@index([goalId])
  @@map("progress_condition_progresses")
}

model BuildPost {
  id                String           @id @default(cuid())
  title             String
  normalizedTitle   String           @unique @map("normalized_title")
  questName         String?          @map("quest_name")
  overview          String?
  supplementalNotes String?          @map("supplemental_notes")
  referenceUrl      String?          @map("reference_url")
  ownerId           String           @map("owner_id")
  owner             User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images            BuildPostImage[]
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@index([updatedAt])
  @@index([ownerId, updatedAt])
  @@map("build_posts")
}

model BuildPostImage {
  id            String    @id @default(cuid())
  buildPostId   String    @map("build_post_id")
  storageBucket String    @default("gbf-build-screenshots") @map("storage_bucket")
  storagePath   String    @map("storage_path")
  publicUrl     String?   @map("public_url")
  originalName  String?   @map("original_name")
  mimeType      String?   @map("mime_type")
  sizeBytes     Int?      @map("size_bytes")
  displayOrder  Int       @default(0) @map("display_order")
  buildPost     BuildPost @relation(fields: [buildPostId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([buildPostId, displayOrder])
  @@map("build_post_images")
}

model BuildDraft {
  id                String            @id @default(cuid())
  title             String?
  questName         String?           @map("quest_name")
  overview          String?
  supplementalNotes String?           @map("supplemental_notes")
  referenceUrl      String?           @map("reference_url")
  ownerId           String            @map("owner_id")
  owner             User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images            BuildDraftImage[]
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([ownerId, updatedAt])
  @@map("build_drafts")
}

model BuildDraftImage {
  id            String     @id @default(cuid())
  buildDraftId  String     @map("build_draft_id")
  storageBucket String     @default("gbf-build-screenshots") @map("storage_bucket")
  storagePath   String     @map("storage_path")
  publicUrl     String?    @map("public_url")
  originalName  String?    @map("original_name")
  mimeType      String?    @map("mime_type")
  sizeBytes     Int?       @map("size_bytes")
  displayOrder  Int        @default(0) @map("display_order")
  buildDraft    BuildDraft @relation(fields: [buildDraftId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  @@index([buildDraftId, displayOrder])
  @@map("build_draft_images")
}

model Goal {
  id                   String             @id @default(cuid())
  title                String
  description          String?
  memo                 String?
  visibility           String             @default("personal")
  boardStatus          String             @default("unset") @map("board_status")
  sortOrder            Int                @default(0) @map("sort_order")
  ownerId              String             @map("owner_id")
  owner                User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sourceRoundGoalId    String?            @unique @map("source_round_goal_id")
  sourceRoundGoal      RoundGoal?         @relation(fields: [sourceRoundGoalId], references: [id], onDelete: Cascade)
  sourceProgressGoalId String?            @unique @map("source_progress_goal_id")
  sourceProgressGoal   ProgressGoal?      @relation(fields: [sourceProgressGoalId], references: [id], onDelete: Cascade)
  requiredItems        GoalRequiredItem[]
  raidTargets          GoalRaidTarget[]
  subTasks             GoalSubTask[]
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@index([ownerId, visibility, boardStatus, sortOrder])
  @@index([visibility, boardStatus, sortOrder])
  @@map("goals")
}

model GoalRequiredItem {
  id            String         @id @default(cuid())
  goalId        String
  masterItemId  String?
  itemKind      String         @default("weapon")
  name          String
  requiredCount Int            @default(1)
  currentCount  Int            @default(0)
  importance    String         @default("必須")
  note          String?
  goal          Goal           @relation(fields: [goalId], references: [id], onDelete: Cascade)
  masterItem    GbfMasterItem? @relation(fields: [masterItemId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([goalId])
  @@index([masterItemId])
  @@map("goal_required_items")
}

model GoalRaidTarget {
  id           String   @id @default(cuid())
  goalId       String
  questName    String
  runType      String   @default("other")
  targetCount  Int      @default(0)
  currentCount Int      @default(0)
  note         String?
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([goalId])
  @@map("goal_raid_targets")
}

model GoalSubTask {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  isDone    Boolean  @default(false)
  sortOrder Int      @default(0)
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
  @@map("goal_sub_tasks")
}

model GbfMasterItem {
  id                String             @id
  kind              GbfMasterKind
  name              String
  displayName       String?
  element           String?
  rarity            String?
  category          String?
  thumbnailPath     String?
  thumbnailUrl      String?
  description       String?
  note              String?
  tags              String[]           @default([])
  metadata          Json               @default("{}")
  sortOrder         Int                @default(0)
  isActive          Boolean            @default(true)
  aliases           GbfMasterAlias[]
  goalRequiredItems GoalRequiredItem[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([kind, isActive, sortOrder])
  @@index([kind, name])
  @@map("gbf_master_items")
}

model GbfMasterAlias {
  id              String        @id @default(cuid())
  masterItemId    String
  masterItem      GbfMasterItem @relation(fields: [masterItemId], references: [id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  createdAt       DateTime      @default(now())

  @@unique([masterItemId, normalizedAlias])
  @@index([normalizedAlias])
  @@map("gbf_master_aliases")
}

model GuildWarGoalPlan {
  id                 String              @id @default(cuid())
  title              String
  targetContribution BigInt              @default(0)
  targetMeatCount    BigInt              @default(0)
  memo               String?
  ownerId            String
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  days               GuildWarGoalDay[]
  speeds             GuildWarBossSpeed[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId, updatedAt])
  @@map("guild_war_goal_plans")
}

model GuildWarGoalDay {
  id                  String           @id @default(cuid())
  planId              String
  plan                GuildWarGoalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayLabel            String
  targetContribution  BigInt           @default(0)
  currentContribution BigInt           @default(0)
  sortOrder           Int
  memo                String?

  @@unique([planId, sortOrder])
  @@index([planId])
  @@map("guild_war_goal_days")
}

model GuildWarBossMaster {
  id              String   @id @default(cuid())
  eventKey        String
  bossLevel       Int
  name            String
  contribution    BigInt
  meatCost        Int      @default(0)
  specialMeatCost Int      @default(0)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([eventKey, bossLevel])
  @@index([eventKey, isEnabled, bossLevel])
  @@map("guild_war_boss_masters")
}

model GuildWarBossSpeed {
  id                     String           @id @default(cuid())
  planId                 String
  plan                   GuildWarGoalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  bossLevel              Int
  clearTimeSeconds       Int?
  targetClearTimeSeconds Int?
  targetRuns             Int              @default(0)
  playStyle              String           @default("未指定")
  memo                   String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@unique([planId, bossLevel])
  @@index([planId])
  @@map("guild_war_boss_speeds")
}

model SourceArticle {
  id              String              @id @default(cuid())
  source          String
  sourceArticleId String              @map("source_article_id")
  slug            String?
  title           String
  officialUrl     String              @map("official_url")
  publishedAt     DateTime?           @map("published_at")
  categoryIds     Int[]               @default([]) @map("category_ids")
  categorySlugs   String[]            @default([]) @map("category_slugs")
  articleType     SourceArticleType   @default(other) @map("article_type")
  fetchedAt       DateTime            @default(now()) @map("fetched_at")
  lastCheckedAt   DateTime            @default(now()) @map("last_checked_at")
  contentHash     String?             @map("content_hash")
  status          SourceArticleStatus @default(active)
  extractedItems  ExtractedNewsItem[]

  @@unique([source, sourceArticleId])
  @@index([source, publishedAt])
  @@index([source, articleType])
  @@index([source, status])
  @@index([contentHash])
  @@map("source_articles")
}

model OfficialNewsCategory {
  id               String   @id @default(cuid())
  source           String
  sourceCategoryId Int      @map("source_category_id")
  slug             String
  name             String
  sortOrder        Int      @default(0) @map("sort_order")
  fetchedAt        DateTime @default(now()) @map("fetched_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([source, sourceCategoryId])
  @@unique([source, slug])
  @@index([source, sortOrder])
  @@map("official_news_categories")
}

model ExtractedNewsItem {
  id                   String                  @id @default(cuid())
  sourceArticleId      String                  @map("source_article_id")
  sourceArticle        SourceArticle           @relation(fields: [sourceArticleId], references: [id], onDelete: Cascade)
  itemType             ExtractedNewsItemType   @default(other) @map("item_type")
  title                String?
  eventType            ExtractedNewsEventType  @default(unknown) @map("event_type")
  startsAt             DateTime?               @map("starts_at")
  endsAt               DateTime?               @map("ends_at")
  updateAtCandidate    DateTime?               @map("update_at_candidate")
  rawDateText          String?                 @map("raw_date_text")
  summary              String?
  infoStatus           ExtractedNewsInfoStatus @default(unknown) @map("info_status")
  extractionConfidence Float                   @default(0) @map("extraction_confidence")
  tags                 String[]                @default([])
  relatedKey           String?                 @map("related_key")
  displayPriority      Int                     @default(0) @map("display_priority")
  isVisible            Boolean                 @default(true) @map("is_visible")
  eventNotes           EventNote[]
  eventOccurrences     EventOccurrence[]
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  @@index([sourceArticleId])
  @@index([itemType])
  @@index([eventType])
  @@index([infoStatus])
  @@index([startsAt])
  @@index([endsAt])
  @@map("extracted_news_items")
}

model EventSeries {
  id                  String            @id @default(cuid())
  eventKey            String            @unique @map("event_key")
  name                String
  eventType           String            @map("event_type")
  description         String?
  defaultMemoTemplate String?           @map("default_memo_template")
  occurrences         EventOccurrence[]
  eventNotes          EventNote[]
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([eventType])
  @@map("event_series")
}

model EventOccurrence {
  id               String             @id @default(cuid())
  eventSeriesId    String             @map("event_series_id")
  eventSeries      EventSeries        @relation(fields: [eventSeriesId], references: [id], onDelete: Cascade)
  newsItemId       String?            @map("news_item_id")
  newsItem         ExtractedNewsItem? @relation(fields: [newsItemId], references: [id], onDelete: SetNull)
  title            String
  startAt          DateTime?          @map("start_at")
  endAt            DateTime?          @map("end_at")
  element          String?
  enemyElement     String?            @map("enemy_element")
  advantageElement String?            @map("advantage_element")
  sourceType       String             @default("unknown") @map("source_type")
  sourceArticleId  String?            @map("source_article_id")
  officialUrl      String?            @map("official_url")
  confidence       String             @default("unknown")
  memo             String?
  isVisible        Boolean            @default(true) @map("is_visible")
  eventNotes       EventNote[]
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([eventSeriesId])
  @@index([newsItemId])
  @@index([startAt])
  @@index([endAt])
  @@index([sourceType])
  @@index([confidence])
  @@index([isVisible])
  @@map("event_occurrences")
}

model EventNote {
  id                String             @id @default(cuid())
  eventKey          String             @map("event_key")
  newsItemId        String?            @map("news_item_id")
  newsItem          ExtractedNewsItem? @relation(fields: [newsItemId], references: [id], onDelete: SetNull)
  eventOccurrenceId String?            @map("event_occurrence_id")
  eventOccurrence   EventOccurrence?   @relation(fields: [eventOccurrenceId], references: [id], onDelete: Cascade)
  eventSeriesId     String?            @map("event_series_id")
  eventSeries       EventSeries?       @relation(fields: [eventSeriesId], references: [id], onDelete: SetNull)
  title             String
  minimumGoals      String?            @map("minimum_goals")
  targetWeapons     String?            @map("target_weapons")
  targetSummons     String?            @map("target_summons")
  targetItems       String?            @map("target_items")
  farmingNotes      String?            @map("farming_notes")
  cautionNotes      String?            @map("caution_notes")
  freeMemo          String?            @map("free_memo")
  sourceNoteId      String?            @map("source_note_id")
  sourceNote        EventNote?         @relation("EventNoteCopies", fields: [sourceNoteId], references: [id], onDelete: SetNull)
  copiedNotes       EventNote[]        @relation("EventNoteCopies")
  links             EventNoteLink[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([newsItemId])
  @@index([eventOccurrenceId])
  @@index([eventSeriesId])
  @@index([eventKey])
  @@index([sourceNoteId])
  @@map("event_notes")
}

model EventNoteLink {
  id          String    @id @default(cuid())
  eventNoteId String    @map("event_note_id")
  eventNote   EventNote @relation(fields: [eventNoteId], references: [id], onDelete: Cascade)
  url         String
  title       String?
  siteName    String?   @map("site_name")
  memo        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([eventNoteId, url])
  @@index([eventNoteId])
  @@map("event_note_links")
}

model NewsFetchLog {
  id            String    @id @default(cuid())
  runType       String    @map("run_type")
  targetPeriod  String?   @map("target_period")
  fetchedCount  Int       @default(0) @map("fetched_count")
  insertedCount Int       @default(0) @map("inserted_count")
  updatedCount  Int       @default(0) @map("updated_count")
  failedCount   Int       @default(0) @map("failed_count")
  errorMessage  String?   @map("error_message")
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  @@index([runType, startedAt])
  @@map("news_fetch_logs")
}
