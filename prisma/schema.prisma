generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepeatType {
  daily
  weekly
  once
}

enum GbfMasterKind {
  character
  weapon
  summon
  job
  material
  quest
}

enum SourceArticleStatus {
  active
  archived
  fetch_error
}

enum SourceArticleType {
  monthly_plan
  event
  campaign
  update
  gacha
  character
  media
  maintenance
  other
}

enum ExtractedNewsItemType {
  event
  campaign
  update
  monthly_plan_item
  gacha
  character
  maintenance
  other
}

enum ExtractedNewsEventType {
  scenario_event
  rerun_event
  collaboration_event
  guild_war
  dread_barrage
  rotb
  xeno_clash
  proving_grounds
  tower_of_babyl
  arcarum_event
  side_story
  special_event
  unknown
}

enum ExtractedNewsInfoStatus {
  confirmed
  scheduled
  tentative
  unknown
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tasks        Task[]
  materialGoals MaterialGoal[]
  materialPresets MaterialPreset[]
  buildPosts   BuildPost[]
  guildWarGoalPlans GuildWarGoalPlan[]
  sharedGoals  SharedGoal[] @relation("SharedGoalOwner")
  proposedGoals SharedGoal[] @relation("SharedGoalProposer")
  sentGoalProposals GoalProposal[] @relation("GoalProposalProposer")
  receivedGoalProposals GoalProposal[] @relation("GoalProposalTarget")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  category     String     @default("日課")
  repeatType   RepeatType @default(daily)
  dueDate      DateTime?
  resetHourJst Int        @default(5)
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?
  ownerId      String
  owner        User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([ownerId, isCompleted])
  @@index([ownerId, repeatType])
}

model MaterialGoal {
  id        String         @id @default(cuid())
  title     String
  questName String?
  note      String?
  ownerId   String
  owner     User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items     MaterialItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([ownerId, updatedAt])
}

model MaterialItem {
  id            String       @id @default(cuid())
  name          String
  requiredCount Int
  ownedCount    Int          @default(0)
  note          String?
  goalId        String
  goal          MaterialGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([goalId])
}

model MaterialPreset {
  id        String               @id @default(cuid())
  name      String
  questName String?
  note      String?
  ownerId   String
  owner     User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items     MaterialPresetItem[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([ownerId, updatedAt])
}

model MaterialPresetItem {
  id            String         @id @default(cuid())
  name          String
  requiredCount Int
  note          String?
  presetId      String
  preset        MaterialPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([presetId])
}

model BuildPost {
  id                  String   @id @default(cuid())
  title               String
  category            String
  questName           String
  element             String
  purpose             String
  operationType       String
  verificationStatus  String
  overview            String?
  protagonistJob      String?
  characterDetails    Json     @default("[]")
  summonDetails       Json     @default("[]")
  weaponDetails       Json     @default("[]")
  characters          String[] @default([])
  summons             String[] @default([])
  weapons             String[] @default([])
  requiredParts       String[] @default([])
  recommendedParts    String[] @default([])
  substitutableParts  String[] @default([])
  freeSlots           String[] @default([])
  substituteNotes     String?
  cautions            String?
  role                String?
  omenNotes           String?
  actionNotes         String?
  failurePoints       String?
  farmingGoal         String?
  raidRole            String?
  blueChest           String?
  clearTime           String?
  stability           String?
  prerequisites       String?
  weaponTarget        String?
  rescueTiming        String?
  farmingCautions     String?
  referenceUrls       Json     @default("[]")
  sourcePresetId      String?
  sourcePresetName    String?
  changeMemo          String?
  ownerId             String
  owner               User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images              BuildPostImage[]
  goalLinks           GoalBuildLink[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ownerId, updatedAt])
  @@index([ownerId, category, questName, element])
}

model BuildPostImage {
  id           String    @id @default(cuid())
  buildPostId  String
  imageType    String
  storageBucket String   @default("gbf-build-screenshots")
  storagePath  String
  publicUrl    String?
  originalName String?
  mimeType     String?
  sizeBytes    Int?
  displayOrder Int       @default(0)
  buildPost    BuildPost @relation(fields: [buildPostId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([buildPostId, displayOrder])
  @@map("build_post_images")
}

model SharedGoal {
  id                 String        @id @default(cuid())
  title              String
  category           String
  description        String?
  targetValue        Float?
  currentValue       Float?
  unit               String?
  details            Json          @default("{}")
  progressRate       Float?
  status             String        @default("未達成")
  boardStatus        String        @default("later")
  priority           String        @default("medium")
  effort             String        @default("normal")
  dueDate            DateTime?
  beginnerRecommended Boolean      @default(false)
  sortOrder          Int           @default(0)
  memo               String?
  sourceProposalId   String?       @unique
  sourceProposal     GoalProposal? @relation("GoalSourceProposal", fields: [sourceProposalId], references: [id], onDelete: SetNull)
  proposedByUserId   String?
  proposedByUser     User?         @relation("SharedGoalProposer", fields: [proposedByUserId], references: [id], onDelete: SetNull)
  ownerId            String
  owner              User          @relation("SharedGoalOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  acceptedProposal   GoalProposal? @relation("GoalProposalAcceptedGoal")
  buildLinks         GoalBuildLink[]
  requiredItems      GoalRequiredItem[]
  raidTargets        GoalRaidTarget[]
  subTasks           GoalSubTask[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([ownerId, status])
  @@index([ownerId, boardStatus, sortOrder])
  @@index([priority])
  @@index([effort])
  @@index([category, status])
  @@index([dueDate])
  @@map("shared_goals")
}

model GoalBuildLink {
  id        String     @id @default(cuid())
  goalId    String
  buildId   String
  note      String?
  goal      SharedGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  build     BuildPost  @relation(fields: [buildId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([goalId, buildId])
  @@index([goalId])
  @@index([buildId])
  @@map("goal_build_links")
}

model GoalRequiredItem {
  id            String        @id @default(cuid())
  goalId        String
  masterItemId  String?
  itemKind      String        @default("weapon")
  name          String
  requiredCount Int           @default(1)
  currentCount  Int           @default(0)
  importance    String        @default("必須")
  note          String?
  goal          SharedGoal    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  masterItem    GbfMasterItem? @relation(fields: [masterItemId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([goalId])
  @@index([masterItemId])
  @@map("goal_required_items")
}

model GoalRaidTarget {
  id           String     @id @default(cuid())
  goalId       String
  questName    String
  runType      String     @default("other")
  targetCount  Int        @default(0)
  currentCount Int        @default(0)
  note         String?
  goal         SharedGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([goalId])
  @@map("goal_raid_targets")
}

model GoalSubTask {
  id        String     @id @default(cuid())
  goalId    String
  title     String
  isDone    Boolean    @default(false)
  sortOrder Int        @default(0)
  goal      SharedGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([goalId])
  @@map("goal_sub_tasks")
}

model GoalProposal {
  id             String      @id @default(cuid())
  proposerUserId String
  proposer       User        @relation("GoalProposalProposer", fields: [proposerUserId], references: [id], onDelete: Cascade)
  targetUserId   String
  targetUser     User        @relation("GoalProposalTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  title          String
  category       String
  description    String?
  targetValue    Float?
  unit           String?
  details        Json        @default("{}")
  dueDate        DateTime?
  proposalMemo   String?
  status         String      @default("提案中")
  acceptedGoalId String?     @unique
  acceptedGoal   SharedGoal? @relation("GoalProposalAcceptedGoal", fields: [acceptedGoalId], references: [id], onDelete: SetNull)
  sourcedGoal    SharedGoal? @relation("GoalSourceProposal")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([targetUserId, status])
  @@index([proposerUserId, status])
  @@map("goal_proposals")
}

model GbfMasterItem {
  id            String           @id
  kind          GbfMasterKind
  name          String
  displayName   String?
  element       String?
  rarity        String?
  category      String?
  thumbnailPath String?
  thumbnailUrl  String?
  description   String?
  note          String?
  tags          String[]         @default([])
  metadata      Json             @default("{}")
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true)
  aliases       GbfMasterAlias[]
  goalRequiredItems GoalRequiredItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([kind, isActive, sortOrder])
  @@index([kind, name])
  @@map("gbf_master_items")
}

model GbfMasterAlias {
  id              String        @id @default(cuid())
  masterItemId    String
  masterItem      GbfMasterItem @relation(fields: [masterItemId], references: [id], onDelete: Cascade)
  alias           String
  normalizedAlias String
  createdAt       DateTime      @default(now())

  @@unique([masterItemId, normalizedAlias])
  @@index([normalizedAlias])
  @@map("gbf_master_aliases")
}

model GuildWarGoalPlan {
  id                 String              @id @default(cuid())
  title              String
  targetContribution BigInt              @default(0)
  targetMeatCount    BigInt              @default(0)
  memo               String?
  ownerId            String
  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  days               GuildWarGoalDay[]
  speeds             GuildWarBossSpeed[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([ownerId, updatedAt])
  @@map("guild_war_goal_plans")
}

model GuildWarGoalDay {
  id                 String           @id @default(cuid())
  planId             String
  plan               GuildWarGoalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayLabel           String
  targetContribution BigInt           @default(0)
  currentContribution BigInt          @default(0)
  sortOrder          Int
  memo               String?

  @@unique([planId, sortOrder])
  @@index([planId])
  @@map("guild_war_goal_days")
}

model GuildWarBossMaster {
  id              String   @id @default(cuid())
  eventKey        String
  bossLevel       Int
  name            String
  contribution    BigInt
  meatCost        Int      @default(0)
  specialMeatCost Int      @default(0)
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([eventKey, bossLevel])
  @@index([eventKey, isEnabled, bossLevel])
  @@map("guild_war_boss_masters")
}

model GuildWarBossSpeed {
  id               String           @id @default(cuid())
  planId           String
  plan             GuildWarGoalPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  bossLevel        Int
  clearTimeSeconds Int?
  targetClearTimeSeconds Int?
  targetRuns       Int              @default(0)
  playStyle        String           @default("未指定")
  memo             String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([planId, bossLevel])
  @@index([planId])
  @@map("guild_war_boss_speeds")
}

model SourceArticle {
  id              String                @id @default(cuid())
  source          String
  sourceArticleId String                @map("source_article_id")
  slug            String?
  title           String
  officialUrl     String                @map("official_url")
  publishedAt     DateTime?             @map("published_at")
  categoryIds     Int[]                 @default([]) @map("category_ids")
  categorySlugs   String[]              @default([]) @map("category_slugs")
  articleType     SourceArticleType     @default(other) @map("article_type")
  fetchedAt       DateTime              @default(now()) @map("fetched_at")
  lastCheckedAt   DateTime              @default(now()) @map("last_checked_at")
  contentHash     String?               @map("content_hash")
  status          SourceArticleStatus   @default(active)
  extractedItems  ExtractedNewsItem[]

  @@unique([source, sourceArticleId])
  @@index([source, publishedAt])
  @@index([source, articleType])
  @@index([source, status])
  @@index([contentHash])
  @@map("source_articles")
}

model OfficialNewsCategory {
  id               String   @id @default(cuid())
  source           String
  sourceCategoryId Int      @map("source_category_id")
  slug             String
  name             String
  sortOrder        Int      @default(0) @map("sort_order")
  fetchedAt        DateTime @default(now()) @map("fetched_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([source, sourceCategoryId])
  @@unique([source, slug])
  @@index([source, sortOrder])
  @@map("official_news_categories")
}

model ExtractedNewsItem {
  id                   String                  @id @default(cuid())
  sourceArticleId      String                  @map("source_article_id")
  sourceArticle        SourceArticle           @relation(fields: [sourceArticleId], references: [id], onDelete: Cascade)
  itemType             ExtractedNewsItemType   @default(other) @map("item_type")
  title                String?
  eventType            ExtractedNewsEventType  @default(unknown) @map("event_type")
  startsAt             DateTime?               @map("starts_at")
  endsAt               DateTime?               @map("ends_at")
  updateAtCandidate    DateTime?               @map("update_at_candidate")
  rawDateText          String?                 @map("raw_date_text")
  summary              String?
  infoStatus           ExtractedNewsInfoStatus @default(unknown) @map("info_status")
  extractionConfidence Float                   @default(0) @map("extraction_confidence")
  tags                 String[]                @default([])
  relatedKey           String?                 @map("related_key")
  displayPriority      Int                     @default(0) @map("display_priority")
  isVisible            Boolean                 @default(true) @map("is_visible")
  eventNotes           EventNote[]
  eventOccurrences     EventOccurrence[]
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  @@index([sourceArticleId])
  @@index([itemType])
  @@index([eventType])
  @@index([infoStatus])
  @@index([startsAt])
  @@index([endsAt])
  @@map("extracted_news_items")
}

model EventSeries {
  id                  String            @id @default(cuid())
  eventKey            String            @unique @map("event_key")
  name                String
  eventType           String            @map("event_type")
  description         String?
  defaultMemoTemplate String?           @map("default_memo_template")
  occurrences         EventOccurrence[]
  eventNotes          EventNote[]
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([eventType])
  @@map("event_series")
}

model EventOccurrence {
  id               String             @id @default(cuid())
  eventSeriesId    String             @map("event_series_id")
  eventSeries      EventSeries        @relation(fields: [eventSeriesId], references: [id], onDelete: Cascade)
  newsItemId       String?            @map("news_item_id")
  newsItem         ExtractedNewsItem? @relation(fields: [newsItemId], references: [id], onDelete: SetNull)
  title            String
  startAt          DateTime?          @map("start_at")
  endAt            DateTime?          @map("end_at")
  element          String?
  enemyElement     String?            @map("enemy_element")
  advantageElement String?            @map("advantage_element")
  sourceType       String             @default("unknown") @map("source_type")
  sourceArticleId  String?            @map("source_article_id")
  officialUrl      String?            @map("official_url")
  confidence       String             @default("unknown")
  memo             String?
  isVisible        Boolean            @default(true) @map("is_visible")
  eventNotes       EventNote[]
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([eventSeriesId])
  @@index([newsItemId])
  @@index([startAt])
  @@index([endAt])
  @@index([sourceType])
  @@index([confidence])
  @@index([isVisible])
  @@map("event_occurrences")
}

model EventNote {
  id              String             @id @default(cuid())
  eventKey        String             @map("event_key")
  newsItemId      String?            @map("news_item_id")
  newsItem        ExtractedNewsItem? @relation(fields: [newsItemId], references: [id], onDelete: SetNull)
  eventOccurrenceId String?          @map("event_occurrence_id")
  eventOccurrence EventOccurrence?   @relation(fields: [eventOccurrenceId], references: [id], onDelete: Cascade)
  eventSeriesId   String?            @map("event_series_id")
  eventSeries     EventSeries?       @relation(fields: [eventSeriesId], references: [id], onDelete: SetNull)
  title           String
  minimumGoals    String?            @map("minimum_goals")
  targetWeapons   String?            @map("target_weapons")
  targetSummons   String?            @map("target_summons")
  targetItems     String?            @map("target_items")
  farmingNotes    String?            @map("farming_notes")
  cautionNotes    String?            @map("caution_notes")
  freeMemo        String?            @map("free_memo")
  sourceNoteId    String?            @map("source_note_id")
  sourceNote      EventNote?         @relation("EventNoteCopies", fields: [sourceNoteId], references: [id], onDelete: SetNull)
  copiedNotes     EventNote[]        @relation("EventNoteCopies")
  links           EventNoteLink[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([newsItemId])
  @@index([eventOccurrenceId])
  @@index([eventSeriesId])
  @@index([eventKey])
  @@index([sourceNoteId])
  @@map("event_notes")
}

model EventNoteLink {
  id          String    @id @default(cuid())
  eventNoteId String    @map("event_note_id")
  eventNote   EventNote @relation(fields: [eventNoteId], references: [id], onDelete: Cascade)
  url         String
  title       String?
  siteName    String?   @map("site_name")
  memo        String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([eventNoteId, url])
  @@index([eventNoteId])
  @@map("event_note_links")
}

model NewsFetchLog {
  id            String    @id @default(cuid())
  runType       String    @map("run_type")
  targetPeriod  String?   @map("target_period")
  fetchedCount  Int       @default(0) @map("fetched_count")
  insertedCount Int       @default(0) @map("inserted_count")
  updatedCount  Int       @default(0) @map("updated_count")
  failedCount   Int       @default(0) @map("failed_count")
  errorMessage  String?   @map("error_message")
  startedAt     DateTime  @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  @@index([runType, startedAt])
  @@map("news_fetch_logs")
}
